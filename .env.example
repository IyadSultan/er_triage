# Copy this file to ".env" and fill in real values. NEVER commit your .env.
#
# In development, python-dotenv loads this automatically.
# On Render, set these same names in the dashboard under "Environment".

# --- LLM ---------------------------------------------------------------------
# The oncologic-emergency extractor needs this. Without it the app still runs;
# it just records triages with extractor_status="failed" and no flags.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Django core (production) ------------------------------------------------
# Generate a real one with:  python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=
DEBUG=true
# Comma-separated hostnames. On Render, RENDER_EXTERNAL_HOSTNAME is added for you.
ALLOWED_HOSTS=

# --- PHI protection ----------------------------------------------------------
# Generate a Fernet key with:  python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=
# Any integer; changes the MRN obfuscation. Optional.
OPTIMUS_RANDOM=

# --- Database (optional) -----------------------------------------------------
# Leave blank to use SQLite (default). Set to a Postgres URL to use Render Postgres.
# DATABASE_URL=postgres://user:pass@host:5432/dbname
# Where the SQLite file lives (point at a Render persistent disk to keep data):
# SQLITE_PATH=/var/data/db.sqlite3
